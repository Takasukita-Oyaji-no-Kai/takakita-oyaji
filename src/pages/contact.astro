---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import Squiggle from "../components/Squiggle.astro";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "contact");
if (cacheHint) Astro.cache.set(cacheHint);
---

<Base
	title="お問い合わせ"
	description="高北おやじの会へのお問い合わせはこちらから。"
	content={page ? { collection: "pages", id: page.data.id, slug: "contact" } : undefined}
>
	<section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
		<header class="text-center">
			<h1 class="text-4xl font-bold text-foreground sm:text-5xl">
				{page?.data.title ?? "お問い合わせ"}
			</h1>
			<p class="mt-4 text-lg text-muted-foreground">
				高北おやじの会への入会希望や活動に関するお問い合わせは、<br />
				メールにてお願いします。
			</p>
		</header>

		<Squiggle />

		<div class="mx-auto grid max-w-4xl gap-12 sm:grid-cols-[1fr_1.2fr]">
			{/* Left column: contact info */}
			<aside class="space-y-6">
				<div>
					<h2 class="text-sm font-medium uppercase tracking-wider text-muted-foreground">
						メールアドレス
					</h2>
					<a
						href="mailto:info@takakitaoyaji.com"
						class="mt-2 inline-block text-lg text-primary hover:opacity-80"
					>
						info@takakitaoyaji.com
					</a>
				</div>

				<div>
					<h2 class="text-sm font-medium uppercase tracking-wider text-muted-foreground">
						入会について
					</h2>
					<p class="mt-2 text-foreground/90">入会費用はかかりません。</p>
					<p class="mt-1 text-sm text-foreground/70">
						入会いただきますと、おやじの会の連絡メールが届くようになります。
					</p>
				</div>

				{
					page?.data.body && (
						<div class="prose-body text-sm text-foreground/80" {...page.edit.body}>
							<PortableText value={page.data.body} />
						</div>
					)
				}
			</aside>

			{/* Right column: form */}
			<form id="contact-form" class="space-y-5">
				<div>
					<label
						for="contact-name"
						class="block text-sm font-medium text-foreground"
					>
						お名前
					</label>
					<input
						id="contact-name"
						name="name"
						type="text"
						required
						class="mt-1 w-full border-0 border-b border-input bg-transparent px-0 py-2 text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-0"
					/>
				</div>

				<div>
					<label
						for="contact-email"
						class="block text-sm font-medium text-foreground"
					>
						メールアドレス
					</label>
					<input
						id="contact-email"
						name="email"
						type="email"
						required
						class="mt-1 w-full border-0 border-b border-input bg-transparent px-0 py-2 text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-0"
					/>
				</div>

				<div>
					<label
						for="contact-message"
						class="block text-sm font-medium text-foreground"
					>
						メッセージ
					</label>
					<textarea
						id="contact-message"
						name="message"
						required
						rows="5"
						class="mt-1 w-full border-0 border-b border-input bg-transparent px-0 py-2 text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-0"
					></textarea>
				</div>

				<button
					type="submit"
					class="w-full rounded-md bg-primary px-5 py-2.5 font-medium text-primary-foreground transition-opacity hover:opacity-90"
				>
					メールで送信
				</button>
			</form>
		</div>
	</section>
</Base>

<script>
	const form = document.getElementById("contact-form") as HTMLFormElement | null;
	if (form) {
		form.addEventListener("submit", (e) => {
			e.preventDefault();
			const data = new FormData(form);
			const name = (data.get("name") ?? "").toString().trim();
			const email = (data.get("email") ?? "").toString().trim();
			const message = (data.get("message") ?? "").toString().trim();

			const subject = `【ホームページから】${name || "お問い合わせ"}`;
			const body = `お名前: ${name}\nメールアドレス: ${email}\n\n${message}\n`;
			const href = `mailto:info@takakitaoyaji.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
			window.location.href = href;
		});
	}
</script>
