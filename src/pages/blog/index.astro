---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import Squiggle from "../../components/Squiggle.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("blog", {
	status: "published",
	orderBy: { published_at: "desc" },
});
if (cacheHint) Astro.cache.set(cacheHint);

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const o = img as Record<string, unknown>;
	if (typeof o.src === "string" && o.src) return o.src;
	const meta = o.meta as Record<string, unknown> | undefined;
	const key =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof o.id === "string" ? o.id : undefined);
	return key ? `/_emdash/api/media/file/${key}` : undefined;
}

function formatDate(d: Date | null | undefined) {
	if (!d) return null;
	return d.toLocaleDateString("ja-JP", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}
---

<Base title="ブログ" description="高北おやじの会の活動報告ブログ">
	<section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
		<header class="text-center">
			<h1 class="text-4xl font-bold text-foreground sm:text-5xl">ブログ</h1>
			<p class="mt-4 text-lg text-muted-foreground">
				活動の様子や日々の出来事をお伝えします。
			</p>
		</header>

		<Squiggle />

		{
			posts.length === 0 ? (
				<div class="mt-12 rounded-lg border border-dashed border-border bg-card p-12 text-center">
					<p class="text-muted-foreground">まだ投稿はありません。</p>
				</div>
			) : (
				<div class="mt-12 space-y-12">
					{posts.map((post) => {
						const imgUrl = getImageUrl(post.data.featured_image);
						return (
							<article class="grid items-center gap-8 sm:grid-cols-[1fr_1.2fr]">
								{imgUrl && (
									<a
										href={`/blog/${post.id}`}
										class="block overflow-hidden rounded-lg sm:-ml-6"
									>
										<img
											src={imgUrl}
											alt={post.data.title}
											class="aspect-[4/3] w-full object-cover transition-transform hover:scale-[1.02]"
										/>
									</a>
								)}
								<div>
									{post.data.publishedAt && (
										<time class="text-sm text-muted-foreground">
											{formatDate(post.data.publishedAt)}
										</time>
									)}
									<h2 class="mt-2 text-2xl font-bold text-foreground">
										<a href={`/blog/${post.id}`} class="hover:text-primary">
											{post.data.title}
										</a>
									</h2>
									{post.data.excerpt && (
										<p class="mt-3 text-foreground/80">{post.data.excerpt}</p>
									)}
									<a
										href={`/blog/${post.id}`}
										class="mt-4 inline-block text-sm font-medium text-primary hover:opacity-80"
									>
										続きを読む →
									</a>
								</div>
							</article>
						);
					})}
				</div>
			)
		}
	</section>
</Base>
