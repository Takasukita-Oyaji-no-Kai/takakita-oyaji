---
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/theme.css";

interface Props {
	title?: string;
	description?: string | null;
	canonical?: string | null;
	robots?: string | null;
	image?: string | null;
	publishedTime?: string | null;
	modifiedTime?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	description,
	canonical,
	robots,
	image,
	publishedTime,
	modifiedTime,
	content,
} = Astro.props;

const siteTitle = "高北おやじの会";
const siteDescription =
	"高洲北小学校 高北おやじの会の公式サイト。子どもたちと一緒に楽しむ、年間を通じたさまざまな活動をご紹介します。";

const fullTitle =
	!title || title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const metaDescription = description ?? siteDescription;

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	title: fullTitle,
	description: metaDescription,
	canonical,
	image,
	content,
	siteName: siteTitle,
	seo: {
		robots,
	},
	articleMeta:
		publishedTime || modifiedTime
			? { publishedTime, modifiedTime }
			: undefined,
});
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<EmDashHead page={pageCtx} />
	</head>
	<body class="flex min-h-screen flex-col bg-background text-foreground">
		<EmDashBodyStart page={pageCtx} />
		<Header />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
