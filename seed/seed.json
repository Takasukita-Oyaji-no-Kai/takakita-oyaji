		"pages": [
			{
				"id": "page-home-hero",
				"slug": "home-hero",
				"status": "published",
				"data": {
					"title": "高北おやじの会",
					"body": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "子どもたちと一緒に楽しむ、年間を通じたさまざまな活動。"
								}
							]
						}
					]
				}
			},
			{
				"id": "page-about",
				"slug": "about",
				"status": "published",
				"data": {
					"title": "私たちについて",
					"body": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "高北おやじの会は、高洲北小学校に通う児童のおやじからなるゆるい集まりです。平成22年（2010年）に設立されました。"
								}
							]
						},
						{
							"_type": "block",
							"style": "h2",
							"children": [{ "_type": "span", "text": "おやじの会とは" }]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "多くの子供たちと触れ合いながら高北のイベント活動を下支えすることで、おやじ同士の絆が広がり、子供たちの健全育成に繋がることを期待しています。"
								}
							]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "同時におやじたち自身もしっかり楽しむことができる会です。おやじたちのやりたいこと（子供たちが喜ぶこと）をどんどん提案いただき、実現することも可能です。これまでにスキー、釣り、BBQなどの実績もあります。"
								}
							]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "常に「できる時に、できることを楽しむ！」をモットーにしていますので、各々のご都合を優先してください。いつでも参加することができます。"
								}
							]
						}
					]
				}
			},
			{
				"id": "page-contact",
				"slug": "contact",
				"status": "published",
				"data": {
					"title": "お問い合わせ",
					"body": [
						{
							"_type": "block",
							"style": "h3",
							"children": [{ "_type": "span", "text": "メールアドレス" }]
						},
						{
							"_type": "block",
							"style": "normal",
							"markDefs": [
								{
									"_key": "contact-email-link",
									"_type": "link",
									"href": "mailto:info@takakitaoyaji.com"
								}
							],
							"children": [
								{
									"_type": "span",
									"text": "info@takakitaoyaji.com",
									"marks": ["contact-email-link"]
								}
							]
						},
						{
							"_type": "block",
							"style": "h3",
							"children": [{ "_type": "span", "text": "入会について" }]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{ "_type": "span", "text": "入会費用はかかりません。" }
							]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "ご入会いただきますと、おやじの会の連絡メールが届くようになります。"
								}
							]
						},
						{
							"_type": "block",
							"style": "h3",
							"children": [{ "_type": "span", "text": "返信について" }]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "お問い合わせには数日以内にご返信いたします。お気軽にどうぞ。"
								}
							]
						}
					]
				}
			}
